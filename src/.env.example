# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id
VITE_FIREBASE_APP_ID=your_firebase_app_id

# ImageKit Configuration (Public Keys - Safe for frontend)
VITE_IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-imagekit-id
VITE_IMAGEKIT_PUBLIC_KEY=public_XXXXX
# Auth endpoint is auto-detected:
#   - localhost → http://localhost:3001/api/auth
#   - ngrok/network → same origin + /api/auth
#   - production → /api/auth (Vercel routing)
